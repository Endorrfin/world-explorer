{
  "name": "world-explorer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Interactive world map for learning countries, capitals, flags and facts with kids.",
  "scripts": {
    "data": "python3 scripts/build_data.py",
    "shapes": "node scripts/build_shapes.mjs",
    "worldmap": "node scripts/build_worldmap.mjs",
    "neighbors": "node scripts/build_neighbors.mjs",
    "uaregions": "node scripts/build_ukraine_regions.mjs",
    "namesuk": "node scripts/build_names_uk.mjs",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "flag-icons": "^7.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "d3-geo": "^3.1.1",
    "topojson-client": "^3.1.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "world-atlas": "^2.0.2",
    "world-countries": "^5.1.0"
  }
}
